# ===== Backend (FastAPI) =====
APP_NAME=AI-VMS
DEBUG=false

# Database
USE_DATABASE=false
DATABASE_URL=postgresql+asyncpg://aivms:aivms@localhost:5432/aivms

# Cache / Event Bus
REDIS_URL=redis://localhost:6379

# Vector DB
QDRANT_URL=http://localhost:6333

# Auth
SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000

# Face Recognition
RECOGNITION_THRESHOLD=0.68
FACE_QUALITY_THRESHOLD=0.4
EMBEDDING_DIMENSION=512
USE_ADAFACE_FALLBACK=true

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=ai-vms

# LLM / Agent
OPENAI_API_KEY=
LANGGRAPH_MODEL=gpt-4.1-mini

# VLM
USE_VLM=false
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Streaming (go2rtc)
GO2RTC_MODE=embedded
GO2RTC_URL=http://localhost:1984
GO2RTC_DIRECT_URL=http://localhost:1984

# Face Recognition Model
# buffalo_l: 고정밀 (GPU 권장), buffalo_sc: 경량 (CPU/저사양 GPU)
FACE_MODEL_NAME=buffalo_l
# 검출 해상도: 640(고정밀/GPU), 320(경량/CPU)
FACE_DET_SIZE=640

# Face Recognition Pipeline
FACE_RECOGNITION_PIPELINE_ENABLED=true

# AI Pipeline
MOTION_GATE_ENABLED=true
PROCESS_INTERVAL_ACTIVE=0.01
PROCESS_INTERVAL_IDLE=0.2
FRAME_SKIP=3

# Danger Detection
DANGER_DETECTION_ENABLED=true
DANGER_MODEL_PATH=./models/yolo11-danger.pt
ACTION_RECOGNITION_ENABLED=true
POSE_MODEL=mediapipe

# ===== Frontend (Next.js) =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_GO2RTC_URL=http://localhost:1984

# ===== GPU 설정 =====
# 호스트에 NVIDIA 드라이버 + nvidia-container-toolkit 필요
# 설치: sudo apt install nvidia-driver-550 nvidia-container-toolkit
# 확인: nvidia-smi && docker run --rm --gpus all nvidia/cuda:12.4.1-base-ubuntu22.04 nvidia-smi
